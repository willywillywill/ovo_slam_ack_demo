<launch>
    <arg name="world"
        default="$(find car)/world/package.xml"/>
    <arg name="gui" default="false"/>
    <arg name="model"
        default="$(find yahboomcar_description)/urdf/yahboomcar_R2.urdf.xacro"/>
    
    <!-- 載入 URDF -->
    <param name="robot_description"
        textfile="$(arg model)"/>

    <!-- 載入控制器設定 -->
    <rosparam
        file="$(find car)/config/controllers.yaml"
        command="load"/>

    <!-- 生成模型 -->
    <node 
        name="spawn_model" 
        pkg="gazebo_ros" 
        type="spawn_model"
        output="screen"
        args="  -file $(arg model)
                -urdf 
                -model yahboomcar
                -x 0
                -y 0
                -z 0.10" 
        />


    <!-- 生成 Gazebo 模型 -->
    <include file="$(find gazebo_ros)/launch/empty_world.launch">
        <arg name="gui" value="$(arg gui)"/>
        <arg name="world_name" value="$(arg world)"/>
        <arg name="use_sim_time" value="true"/>
    </include>
    

    <!-- 發布 TF -->
    <node
        pkg="robot_state_publisher"
        type="robot_state_publisher"
        name="robot_state_publisher"
        output="screen"
        />

    <node
        pkg="controller_manager"
        type="spawner"
        name="controller_spawner"
        output="screen"
        args="
        joint_state_controller
        front_left_steer_controller
        front_right_steer_controller
        back_left_wheel_controller
        back_right_wheel_controller"/>

    <!-- cmd_vel 轉阿克曼關節命令 -->
  <node
        pkg="car"
        type="ackermann_controller.py"
        name="ackermann_controller"
        output="screen">

        <param name="wheelbase" value="0.23529"/>
        <param name="front_track" value="0.13"/>
        <param name="rear_track" value="0.1685"/>

        <!-- 需要依實際輪子大小調整 -->
        <param name="wheel_radius" value="0.0325"/>

        <param name="max_steering" value="0.6"/>
        <param name="max_wheel_speed" value="30.0"/>
    </node>

    <!-- command GUI -->
    <node 
        pkg="rqt_robot_steering"
        type="rqt_robot_steering"
        name="rqt_robot_steering"
        output="screen"
        />

    <node
        pkg="car"
        type="ackermann_odom.py"
        name="ackermann_odom"
        output="screen"
        >

        <param name="wheel_radius" value="0.0325"/>

        <!-- 修改成你的前後輪軸距 -->
        <param name="wheelbase" value="0.23529"/>

        <param
            name="rear_left_joint"
            value="back_left_joint"
        />

        <param
            name="rear_right_joint"
            value="back_right_joint"
        />

        <param
            name="front_left_steer_joint"
            value="front_left_steer_joint"
        />

        <param
            name="front_right_steer_joint"
            value="front_right_steer_joint"
        />

        <param name="odom_frame" value="odom"/>
        <param name="base_frame" value="base_link"/>
        <param name="publish_tf" value="true"/>
        <param name="publish_rate" value="50.0"/>
    </node>


    <!-- GMapping -->
    <node pkg="gmapping"
          type="slam_gmapping"
          name="slam_gmapping"
          output="screen">

        <!-- Topic -->
        <remap from="scan" to="scan"/>

        <!-- TF -->
        <param name="map_frame" value="map"/>
        <param name="odom_frame" value="odom"/>
        <param name="base_frame" value="base_link"/>

        <!-- 地圖更新頻率 -->
        <param name="map_update_interval" value="2.0"/>

        <!-- 雷達有效距離，需小於雷達 max range -->
        <param name="maxUrange" value="11.5"/>
        <param name="maxRange" value="12.0"/>

        <!-- TF 容忍時間 -->
        <param name="transform_publish_period" value="0.05"/>
        <param name="tf_delay" value="0.1"/>

        <!-- 移動多少才更新掃描 -->
        <param name="linearUpdate" value="0.10"/>
        <param name="angularUpdate" value="0.05"/>
        <param name="temporalUpdate" value="0.5"/>

        <!-- 粒子數 -->
        <param name="particles" value="50"/>

        <!-- 掃描匹配參數 -->
        <param name="minimumScore" value="50"/>
        <param name="lskip" value="0"/>

        <!-- 地圖範圍 -->
        <param name="xmin" value="-20.0"/>
        <param name="ymin" value="-20.0"/>
        <param name="xmax" value="20.0"/>
        <param name="ymax" value="20.0"/>

        <!-- 地圖解析度，單位 m/cell -->
        <param name="delta" value="0.05"/>

        <!-- GMapping 常用參數 -->
        <param name="sigma" value="0.05"/>
        <param name="kernelSize" value="1"/>
        <param name="lstep" value="0.05"/>
        <param name="astep" value="0.05"/>
        <param name="iterations" value="5"/>

        <param name="lsigma" value="0.075"/>
        <param name="ogain" value="3.0"/>
        <param name="lskip" value="0"/>

        <param name="srr" value="0.1"/>
        <param name="srt" value="0.2"/>
        <param name="str" value="0.1"/>
        <param name="stt" value="0.2"/>

        <param name="linearThreshold" value="0.05"/>
        <param name="angularThreshold" value="0.05"/>
        <param name="resampleThreshold" value="0.5"/>

        <param name="llsamplerange" value="0.01"/>
        <param name="llsamplestep" value="0.01"/>
        <param name="lasamplerange" value="0.005"/>
        <param name="lasamplestep" value="0.005"/>

    </node>



    <node 
        pkg="rviz"
        name="rviz"
        type="rviz"
        />


</launch>