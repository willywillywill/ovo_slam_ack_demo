<?xml version="1.0"?>

<launch>

  <!-- Gazebo 模擬時間 -->
  <param name="/use_sim_time" value="true"/>

  <!-- 輸入 topics -->
  <arg name="rgb_topic"
       default="/camera/color/image_raw"/>

  <arg name="depth_topic"
       default="/camera/depth/image_raw"/>

  <arg name="camera_info_topic"
       default="/camera/camera_info"/>

  <arg name="scan_topic"
       default="/scan"/>

  <arg name="odom_topic"
       default="/odom"/>

  <!-- RTAB-Map 資料庫 -->
  <arg name="database_path"
       default="$(env HOME)/.ros/car_rtabmap.db"/>

  <group ns="rtabmap">

    <node pkg="rtabmap_slam"
          type="rtabmap"
          name="rtabmap"
          output="screen"
          args="--delete_db_on_start">

      <!-- 資料庫 -->
      <param name="database_path"
             value="$(arg database_path)"/>

      <!-- TF frames -->
      <param name="frame_id"
             value="base_link"/>

      <param name="odom_frame_id"
             value="odom"/>

      <param name="map_frame_id"
             value="map"/>

      <param name="publish_tf"
             value="true"/>

      <!-- 感測器訂閱 -->
      <param name="subscribe_depth"
             value="true"/>

      <param name="subscribe_scan"
             value="true"/>

      <param name="subscribe_odom_info"
             value="false"/>

      <param name="approx_sync"
             value="true"/>

      <param name="queue_size"
             value="50"/>

      <!-- RGB-D topics -->
      <remap from="rgb/image"
             to="$(arg rgb_topic)"/>

      <remap from="depth/image"
             to="$(arg depth_topic)"/>

      <remap from="rgb/camera_info"
             to="$(arg camera_info_topic)"/>

      <!-- LiDAR 與 odometry -->
      <remap from="scan"
             to="$(arg scan_topic)"/>

      <remap from="odom"
             to="$(arg odom_topic)"/>

      <!-- 將 occupancy grid 發布成 /map -->
      <remap from="grid_map"
             to="/map"/>

      <!-- 平面車輛設定 -->
      <param name="Optimizer/Slam2D"
             value="true"/>

      <param name="Reg/Force3DoF"
             value="true"/>

      <!-- 使用視覺＋ICP -->
      <param name="Reg/Strategy"
             value="1"/>

      <!-- 新節點建立條件 -->
      <param name="RGBD/LinearUpdate"
             value="0.05"/>

      <param name="RGBD/AngularUpdate"
             value="0.05"/>

      <!-- 地圖優化 -->
      <param name="RGBD/NeighborLinkRefining"
             value="true"/>

      <param name="RGBD/ProximityBySpace"
             value="true"/>

      <!-- 運算量控制 -->
      <param name="Rtabmap/DetectionRate"
             value="1.0"/>

      <param name="Rtabmap/TimeThr"
             value="700"/>

      <!-- 2D occupancy grid -->
      <param name="Grid/MaxObstacleHeight"
             value="1.7"/>

      <param name="Grid/NoiseFilteringRadius"
             value="0.05"/>

      <param name="Grid/NoiseFilteringMinNeighbors"
             value="5"/>

      <!-- Mapping mode -->
      <param name="Mem/IncrementalMemory"
             value="true"/>

      <param name="Mem/InitWMWithAllNodes"
             value="false"/>

    </node>

  </group>

</launch>